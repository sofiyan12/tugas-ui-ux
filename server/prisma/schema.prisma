generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       String   @default("teacher")
  department String?
  school     String?
  reports    Report[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Report {
  id              String   @id @default(uuid())
  subject         String
  className       String
  date            DateTime
  learningTopic   String   @db.Text
  teachingMethod  String   @db.Text
  studentFeedback String?  @db.Text
  challenges      String?  @db.Text
  attachments     String?
  status          String   @default("Selesai") // Selesai, Menunggu Tinjauan
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
